# LexGenius Pipeline — Environment Variables
# Copy to .env and fill in your values. Never commit .env to version control.

# ── Database ──────────────────────────────────────────────────────────────────
LGP_DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/lexgenius

# ── AI / LLM Providers ────────────────────────────────────────────────────────
LGP_OPENAI_API_KEY=sk-...
LGP_ANTHROPIC_API_KEY=sk-ant-...

# ── Federal Data Sources ──────────────────────────────────────────────────────
# FDA
LGP_FDA_API_KEY=

# SEC / EDGAR
LGP_SEC_USER_AGENT=YourName/1.0 (your@email.com)

# NIH / PubMed
LGP_NIH_API_KEY=

# Congress.gov
LGP_CONGRESS_API_KEY=

# USGS
LGP_USGS_API_KEY=

# ── Ingestion Settings ────────────────────────────────────────────────────────
# Max concurrent HTTP requests per source
LGP_INGESTION_CONCURRENCY=10

# Request timeout in seconds
LGP_INGESTION_TIMEOUT=30

# Retry attempts on transient failures
LGP_INGESTION_MAX_RETRIES=3

# ── Storage ───────────────────────────────────────────────────────────────────
# Local path for raw document cache
LGP_RAW_STORAGE_PATH=/tmp/lexgenius/raw

# S3-compatible object storage (optional)
LGP_S3_BUCKET=
LGP_S3_ENDPOINT_URL=
LGP_S3_ACCESS_KEY=
LGP_S3_SECRET_KEY=

# ── Logging ───────────────────────────────────────────────────────────────────
# Log level: DEBUG, INFO, WARNING, ERROR
LGP_LOG_LEVEL=INFO

# Output format: json or console
LGP_LOG_FORMAT=json

# ── Workflow / Agentic ────────────────────────────────────────────────────────
LGP_WORKFLOW_MAX_PARALLEL_TASKS=4
LGP_WORKFLOW_TASK_TIMEOUT=300

# ── Environment ───────────────────────────────────────────────────────────────
LGP_ENV=development
